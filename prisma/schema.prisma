generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  reviews       Review[]
  cellarItems   CellarItem[]
  tasteProfile  TasteProfile?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wine {
  id             String       @id @default(cuid())
  name           String
  producer       String
  vintage        Int?
  country        String
  region         String?
  subRegion      String?
  grapeVarieties String       @default("[]")
  type           String       @default("RED")
  color          String?
  abv            Float?
  description    String?
  imageUrl       String?
  avgRating      Float        @default(0)
  reviewCount    Int          @default(0)
  vinmonopoletId String?      @unique
  price          Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  reviews        Review[]
  cellarItems    CellarItem[]
  pairings       FoodPairing[]
}

model Review {
  id        String   @id @default(cuid())
  rating    Float
  nose      String?
  palate    String?
  finish    String?
  notes     String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  wine      Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade)
  wineId    String
}

model CellarItem {
  id            String    @id @default(cuid())
  quantity      Int       @default(1)
  purchasePrice Float?
  purchaseDate  DateTime?
  location      String?
  drinkFrom     DateTime?
  drinkBefore   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  wine          Wine      @relation(fields: [wineId], references: [id], onDelete: Cascade)
  wineId        String
}

model FoodPairing {
  id       String @id @default(cuid())
  dish     String
  category String
  strength Int
  wine     Wine   @relation(fields: [wineId], references: [id], onDelete: Cascade)
  wineId   String
}

model TasteProfile {
  id               String @id @default(cuid())
  preferredTypes   String @default("[]")
  preferredRegions String @default("[]")
  flavorNotes      String @default("[]")
  priceRange       String?
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String @unique
}

model Restaurant {
  id            String                   @id @default(cuid())
  name          String
  address       String?
  city          String
  region        String
  area          String?
  venueType     String?
  wineCount     Int?
  rating        Float?
  priceTier     String?
  tags          String                   @default("[]")
  awards        String                   @default("[]")
  description   String?
  documentUrl   String?
  lastUpdated   DateTime?
  confidence    String                   @default("medium")
  rank          Int?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  highlights    RestaurantWineHighlight[]
}

model RestaurantWineHighlight {
  id             String     @id @default(cuid())
  category       String
  wineName       String
  producer       String?
  vintage        Int?
  priceBottleNok Int?
  priceGlassNok  Int?
  pour           String?
  sourceRef      String?
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId   String
}
